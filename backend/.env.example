APP_NAME=Gefther
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
# php artisan serve na maquina + Postgres no Docker: DB_HOST=127.0.0.1 (override expoe 5432).
# API rodando DENTRO do container backend: DB_HOST=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=gefther
DB_USERNAME=gefther
DB_PASSWORD=

# Sessao/cache/fila:
# - Backend no Docker (compose): variaveis CACHE_STORE/SESSION/QUEUE vêm do docker-compose.yml (redis).
# - php artisan serve + docker compose up -d postgres redis: use redis aqui e REDIS_HOST=127.0.0.1.
# - Sem Redis: SESSION_DRIVER=file, CACHE_STORE=file, QUEUE_CONNECTION=sync.
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
# php artisan serve + Redis no Docker (override expoe 6379): 127.0.0.1
# Backend dentro do Compose: redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

# Origens separadas por virgula (sem espacos extras). Render: inclua a URL exata do frontend HTTPS.
# Ex.: https://gefther-frontend.onrender.com
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:5174,http://localhost:8000,http://localhost:3000
SANCTUM_TOKEN_EXPIRATION=480

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
